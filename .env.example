# =============================================================================
# Unified MCP Tool Server - Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment

# =============================================================================
# CORE SERVER CONFIGURATION
# =============================================================================

# Server Identity
MCP_SERVER_NAME=unified-tool-server
MCP_SERVER_VERSION=2.0.0
MCP_PROTOCOL_VERSION=2025-06-18

# Transport Configuration
TRANSPORT_TYPE=streamable-http
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Database Connection Pool
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# Authentication Settings
AUTH_ENABLED=false
OAUTH_ISSUER_URL=
REQUIRED_SCOPES=mcp:read,mcp:write

# API Security
API_KEY_REQUIRED=false
API_KEY_HEADER=X-API-Key
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# CORS Configuration
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_ENDPOINT=/metrics

# Prometheus Configuration
PROMETHEUS_PORT=9091
PROMETHEUS_RETENTION_DAYS=15

# Grafana Configuration  
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/unified_mcp_server.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# Structured Logging
ENABLE_CORRELATION_IDS=true
LOG_REQUEST_BODIES=false
LOG_RESPONSE_BODIES=false

# =============================================================================
# PERFORMANCE & SCALING
# =============================================================================

# Connection Management
MAX_CONCURRENT_CONNECTIONS=1000
CONNECTION_TIMEOUT=300
KEEP_ALIVE_TIMEOUT=65

# Tool Execution
TOOL_EXECUTION_TIMEOUT=30
MAX_PARALLEL_TOOLS=50
TOOL_RETRY_ATTEMPTS=3
TOOL_RETRY_DELAY=1

# Memory Management
MAX_MEMORY_USAGE_MB=1024
GARBAGE_COLLECTION_THRESHOLD=0.8

# =============================================================================
# DOCKER & DEPLOYMENT
# =============================================================================

# Build Configuration
BUILD_VERSION=2.0.0
BUILD_DATE=
VCS_REF=

# Container Resources
CONTAINER_CPU_LIMIT=1.0
CONTAINER_MEMORY_LIMIT=1G
CONTAINER_CPU_RESERVATION=0.5
CONTAINER_MEMORY_RESERVATION=512M

# Nginx Reverse Proxy
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# =============================================================================
# CLOUD DEPLOYMENT
# =============================================================================

# Environment
ENVIRONMENT=development
DEPLOYMENT_MODE=standalone

# Kubernetes Configuration
K8S_NAMESPACE=mcp-tools
K8S_SERVICE_ACCOUNT=mcp-server
K8S_REPLICAS=3

# Load Balancing
LOAD_BALANCER_ENABLED=false
LOAD_BALANCER_ALGORITHM=round_robin
STICKY_SESSIONS=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature Toggles
ENABLE_TOOL_CACHING=true
ENABLE_RESULT_COMPRESSION=true
ENABLE_REQUEST_TRACING=true
ENABLE_AUTO_SCALING=false

# Experimental Features
ENABLE_BETA_FEATURES=false
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_ML_RECOMMENDATIONS=false

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================

# Tool Discovery Services
EXTERNAL_TOOL_REGISTRY_URL=
TOOL_REGISTRY_API_KEY=
ENABLE_AUTO_TOOL_DISCOVERY=true

# Notification Services
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
EMAIL_NOTIFICATIONS_ENABLED=false

# Backup & Recovery
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_STORAGE_PATH=/data/backups

# =============================================================================
# ALERTING & MONITORING
# =============================================================================

# Alert Thresholds
CPU_ALERT_THRESHOLD=80
MEMORY_ALERT_THRESHOLD=85
DISK_ALERT_THRESHOLD=90
ERROR_RATE_ALERT_THRESHOLD=5

# Alert Channels
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=admin@example.com
ALERT_SLACK_ENABLED=false
ALERT_PAGERDUTY_ENABLED=false

# Monitoring Intervals
METRICS_COLLECTION_INTERVAL=15
HEALTH_CHECK_INTERVAL=30
LOG_FLUSH_INTERVAL=5

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Development Mode
DEBUG_MODE=false
DEVELOPMENT_TOOLS_ENABLED=false
HOT_RELOAD_ENABLED=false

# Testing Configuration
TEST_MODE=false
MOCK_EXTERNAL_SERVICES=false
LOAD_TEST_USERS=100

# Profiling
ENABLE_PROFILING=false
PROFILING_SAMPLE_RATE=0.01
PROFILING_OUTPUT_DIR=/tmp/profiles

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Custom Environment Variables
# Add your custom configuration here
CUSTOM_SETTING_1=
CUSTOM_SETTING_2=

# Third-party Service Keys
# Add API keys for external services here
SERVICE_API_KEY_1=
SERVICE_API_KEY_2=