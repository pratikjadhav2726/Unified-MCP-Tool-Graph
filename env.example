# ============================================
# Unified MCP Tool Graph - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# cp env.example .env

# ============================================
# Neo4j Configuration (Optional)
# ============================================
# Required for dynamic tool retrieval and graph-based tool discovery
# If not configured, the system will fall back to popular MCP servers
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ============================================
# Gateway Configuration
# ============================================
# Port for the unified gateway API
GATEWAY_PORT=8000
# Port for the MCP proxy server
PROXY_PORT=9000
# Host binding (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
GATEWAY_HOST=0.0.0.0

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log file path (optional, leave empty for console only)
LOG_FILE=

# ============================================
# SaaS Configuration (For Multi-Tenant Deployment)
# ============================================
# Enable multi-tenancy support
ENABLE_MULTI_TENANCY=false
# API key for authentication (for SaaS deployments)
API_KEY=
# JWT secret for token-based authentication
JWT_SECRET=your_jwt_secret_here_change_in_production
# Token expiration time in hours
JWT_EXPIRATION_HOURS=24

# ============================================
# Rate Limiting (For SaaS)
# ============================================
# Enable rate limiting
ENABLE_RATE_LIMITING=false
# Requests per minute per API key
RATE_LIMIT_PER_MINUTE=60
# Requests per hour per API key
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Database Configuration (For SaaS)
# ============================================
# PostgreSQL connection string (for user management, analytics, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/mcp_gateway
# Redis connection string (for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# ============================================
# MCP Server Configuration
# ============================================
# Maximum number of concurrent MCP server connections
MAX_CONCURRENT_SERVERS=50
# Server timeout in seconds
SERVER_TIMEOUT=30
# Keep servers alive for this many seconds after last use
SERVER_KEEP_ALIVE=600

# ============================================
# Security Configuration
# ============================================
# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Enable HTTPS (requires SSL certificates)
ENABLE_HTTPS=false
# SSL certificate path (if HTTPS enabled)
SSL_CERT_PATH=
# SSL key path (if HTTPS enabled)
SSL_KEY_PATH=

# ============================================
# Monitoring & Observability (For SaaS)
# ============================================
# Enable metrics collection
ENABLE_METRICS=true
# Prometheus metrics endpoint port
METRICS_PORT=9090
# Enable health check endpoint
ENABLE_HEALTH_CHECK=true
# Sentry DSN for error tracking (optional)
SENTRY_DSN=
# OpenTelemetry endpoint (optional)
OTEL_ENDPOINT=

# ============================================
# Feature Flags
# ============================================
# Enable dynamic tool retrieval (requires Neo4j)
ENABLE_DYNAMIC_TOOL_RETRIEVAL=true
# Enable tool usage analytics
ENABLE_ANALYTICS=false
# Enable tool caching
ENABLE_TOOL_CACHE=true
# Cache TTL in seconds
TOOL_CACHE_TTL=3600

# ============================================
# Development/Testing
# ============================================
# Enable debug mode
DEBUG=false
# Enable request/response logging
ENABLE_REQUEST_LOGGING=false
# Mock MCP servers for testing (disable real connections)
MOCK_MCP_SERVERS=false

